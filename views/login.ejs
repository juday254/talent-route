<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - TalentRoute</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('_header') %>

    <main>
        <div class="page-header">
            <h1>Welcome Back</h1>
            <p>Login to your TalentRoute account</p>
        </div>

        <div class="form-container">
            <% if (typeof error !== 'undefined') { %>
                <p style="color:#ef4444; margin-bottom:15px"><%= error %></p>
            <% } %>

            <form action="/login" method="POST">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="Enter your email" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" placeholder="Enter your password" required>
                </div>

                <button type="submit" class="btn" style="width:100%">Login</button>
                <p style="text-align:center; margin-top:15px">Don't have an account? <a href="/signup">Sign Up</a></p>
            </form>
        </div>
    </main>
</body>
</html>