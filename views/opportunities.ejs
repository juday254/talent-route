<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Opportunities - TalentRoute</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('_header') %>

    <main>
        <!-- PAGE HEADER -->
        <section class="page-header">
            <h1>Scholarship Opportunities</h1>
            <p>Explore world-class sports scholarships and development programs</p>
        </section>

        <!-- SEARCH & FILTERS -->
        <div class="container">
            <div class="filter-section">
                <div class="search-bar">
                    <input type="text" id="searchInput" placeholder="Search opportunities by title or university...">
                    <button onclick="filterOpportunities()">Search</button>
                </div>
                <div class="filter-grid">
                    <div class="form-group">
                        <label for="locationFilter">Filter by Location:</label>
                        <select id="locationFilter" onchange="filterOpportunities()">
                            <option value="">All Locations</option>
                            <option value="Kenya">Kenya</option>
                            <option value="USA">USA</option>
                            <option value="UK">UK</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="typeFilter">Filter by Type:</label>
                        <select id="typeFilter" onchange="filterOpportunities()">
                            <option value="">All Types</option>
                            <option value="Full Scholarship">Full Scholarship</option>
                            <option value="Partial">Partial Support</option>
                            <option value="Development">Development Program</option>
                        </select>
                    </div>
                    <div style="display: flex; align-items: flex-end;">
                        <button onclick="resetFilters()" style="width: 100%; padding: 12px; background-color: #666; color: #fff; border: none; border-radius: 5px; cursor: pointer; font-weight: 600;">Reset Filters</button>
                    </div>
                </div>
            </div>

            <!-- OPPORTUNITIES GRID -->
            <div id="opportunitiesContainer" class="cards-grid">
                <!-- JavaScript will populate this -->
            </div>
            <div id="noResults" class="no-results" style="display: none;">
                <p>No opportunities found matching your criteria. Try adjusting your filters.</p>
            </div>
        </div>
    </main>

    <footer>
        <p>&copy; 2026 TalentRoute. All rights reserved.</p>
        <p>Connecting athletic talent with opportunities worldwide</p>
    </footer>

    <script>
        const opportunities = <%- JSON.stringify(opportunities) %>;
        const user = <%- JSON.stringify(user || null) %>;

        function displayOpportunities(data) {
            const container = document.getElementById('opportunitiesContainer');
            const noResults = document.getElementById('noResults');

            if (data.length === 0) {
                container.innerHTML = '';
                noResults.style.display = 'block';
                return;
            }

            noResults.style.display = 'none';
            container.innerHTML = data.map(opp => `
                <div class="card">
                    <div class="card-header">
                        <h3>${opp.title}</h3>
                        <span class="badge">${opp.type}</span>
                    </div>
                    <div class="card-content">
                        <p><strong>University:</strong> ${opp.university}</p>
                        <p><strong>Location:</strong> ${opp.location}</p>
                        <p><strong>Description:</strong> ${opp.description}</p>
                        <p><strong>Requirements:</strong> ${opp.requirements}</p>
                        <a href="${opp.application_link}" target="_blank" class="btn" style="margin-top:15px; display:inline-block;">Apply Now</a>
                        ${user && user.role === 'institution' ? `
                        <form action="/deleteopportunity" method="POST" style="margin-top:10px">
                            <input type="hidden" name="id" value="${opp.id}">
                            <button type="submit" class="btn" style="background-color:#ef4444">Delete</button>
                        </form>` : ''}
                    </div>
                </div>
        `).join('');
        }

        function filterOpportunities() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const locationFilter = document.getElementById('locationFilter').value;
            const typeFilter = document.getElementById('typeFilter').value;

            const filtered = opportunities.filter(opp => {
                const matchesSearch = opp.title.toLowerCase().includes(searchTerm) ||
                                    opp.university.toLowerCase().includes(searchTerm);
                const matchesLocation = !locationFilter || opp.location.includes(locationFilter);
                const matchesType = !typeFilter || opp.type.includes(typeFilter);

                return matchesSearch && matchesLocation && matchesType;
            });

            displayOpportunities(filtered);
        }

        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('locationFilter').value = '';
            document.getElementById('typeFilter').value = '';
            displayOpportunities(opportunities);
        }

        // Initial display
        displayOpportunities(opportunities);

        // Search on Enter key
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                filterOpportunities();
            }
        });
    </script>
</body>
</html>