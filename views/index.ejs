<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TalentRoute - Connect Athletes with Scholarships</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('_header') %>

    <main>
        <!-- HERO SECTION -->
        <section class="hero">
            <h1>Unlock Your Athletic Potential</h1>
            <p>Connect with world-class scholarship opportunities and launch your sports career to the next level</p>
            <div>
                <a href="/talents" class="btn">Browse Talents</a>
                <a href="/opportunities" class="btn secondary">View Opportunities</a>
            </div>
        </section>

        <!-- FEATURES SECTION -->
        <section class="features">
            <div class="container">
                <h2 class="section-title">Why Choose TalentRoute?</h2>
                <div class="features-grid">
                    <div class="feature-card">
                        <div class="icon">🎯</div>
                        <h3>Direct Connections</h3>
                        <p>Connect directly with universities and sports organizations offering scholarships and development programs</p>
                    </div>
                    <div class="feature-card">
                        <div class="icon">📊</div>
                        <h3>Comprehensive Profiles</h3>
                        <p>Build detailed athlete profiles showcasing your achievements, skills, and academic performance</p>
                    </div>
                    <div class="feature-card">
                        <div class="icon">✅</div>
                        <h3>Verified Referrals</h3>
                        <p>Get verified recommendations from coaches and mentors to strengthen your applications</p>
                    </div>
                    <div class="feature-card">
                        <div class="icon">🌍</div>
                        <h3>Global Opportunities</h3>
                        <p>Access scholarships from universities across Kenya, USA, UK, and beyond</p>
                    </div>
                    <div class="feature-card">
                        <div class="icon">📱</div>
                        <h3>Track Applications</h3>
                        <p>Monitor all your applications in one place and stay updated on your opportunities</p>
                    </div>
                    <div class="feature-card">
                        <div class="icon">🏆</div>
                        <h3>Success Stories</h3>
                        <p>Join hundreds of athletes who have successfully secured scholarships through TalentRoute</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- STATS SECTION -->
        <section class="stats">
            <div class="container">
                <div class="stats-grid">
                    <div class="stat-box">
                        <h2>10+</h2>
                        <p>Registered Talents</p>
                    </div>
                    <div class="stat-box">
                        <h2>10+</h2>
                        <p>Active Opportunities</p>
                    </div>
                    <div class="stat-box">
                        <h2>5+</h2>
                        <p>Countries</p>
                    </div>
                    <div class="stat-box">
                        <h2>25+</h2>
                        <p>Total Applications</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA SECTION -->
        <section style="padding: 80px 40px; background-color: var(--light-gray); text-align: center;">
            <div class="container">
                <h2 class="section-title">Ready to Get Started?</h2>
                <p style="font-size: 18px; margin-bottom: 30px; color: #666; max-width: 600px; margin-left: auto; margin-right: auto;">
                    Browse available scholarships and start applying today. Your future in sports awaits!
                </p>
                <a href="/opportunities" class="btn">Explore Opportunities</a>
                <a href="/contact" class="btn secondary">Get in Touch</a>
            </div>
        </section>
    </main>

    <footer>
        <p>&copy; 2026 TalentRoute. All rights reserved.</p>
        <p>Connecting athletic talent with opportunities worldwide</p>
        <p><a href="/contact">Contact Us</a> | <a href="/opportunities">Opportunities</a> | <a href="/talents">Talents</a></p>
    </footer>

    <script>
        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });
    </script>
</body>
</html>
