        function calculateAge(dob) {
            const today = new Date();
            const birthDate = new Date(dob);
            let age = today.getFullYear() - birthDate.getFullYear();
            const monthDiff = today.getMonth() - birthDate.getMonth();
            if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
                age--;
            }
            return age;
        }

        function displayTalents(data) {
            const container = document.getElementById('talentsContainer');
            const noResults = document.getElementById('noResults');

            if (data.length === 0) {
                container.innerHTML = '';
                noResults.style.display = 'block';
                return;
            }

            noResults.style.display = 'none';
            container.innerHTML = data.map(talent => {
                const age = calculateAge(talent.dob);
                return `
                    <div class="card">
                        <div class="card-header">
                            <h3>${talent.fullname}</h3>
                            <span class="sport-badge">${talent.sport}</span>
                        </div>
                        <div class="card-content">
                            <p><strong>Age:</strong> ${age} years old</p>
                            <p><strong>Sport:</strong> ${talent.sport}</p>
                            <p><strong>Education Level:</strong> <span class="badge">${talent.education}</span></p>
                            <p><strong>Achievement:</strong> ${talent.achievement}</p>
                            <p><strong>Contact:</strong></p>
                            <p>📧 ${talent.email}</p>
                            <p>📱 ${talent.phone}</p>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function filterTalents() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const sportFilter = document.getElementById('sportFilter').value;
            const educationFilter = document.getElementById('educationFilter').value;

            const filtered = talents.filter(talent => {
                const matchesSearch = talent.fullname.toLowerCase().includes(searchTerm) ||
                                    talent.sport.toLowerCase().includes(searchTerm);
                const matchesSport = !sportFilter || talent.sport === sportFilter;
                const matchesEducation = !educationFilter || talent.education === educationFilter;

                return matchesSearch && matchesSport && matchesEducation;
            });

            displayTalents(filtered);
        }

        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('sportFilter').value = '';
            document.getElementById('educationFilter').value = '';
            displayTalents(talents);
        }

        // Initial display
        displayTalents(talents);

        // Search on Enter key
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                filterTalents();
            }
        });
    </script>
</body>
</html>