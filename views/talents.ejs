<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Talents - TalentRoute</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('_header') %>

    <main>
        <section class="page-header">
            <h1>Registered Talents</h1>
            <p>Discover elite athletes across Kenya competing at the highest levels</p>
        </section>

        <div class="container">
            <div class="filter-section">
                <div class="search-bar">
                    <input type="text" id="searchInput" placeholder="Search by name or sport...">
                    <button onclick="filterTalents()">Search</button>
                </div>
                <div class="filter-grid">
                    <div class="form-group">
                        <label for="sportFilter">Filter by Sport:</label>
                        <select id="sportFilter" onchange="filterTalents()">
                            <option value="">All Sports</option>
                            <option value="Football">Football</option>
                            <option value="Athletics">Athletics</option>
                            <option value="Basketball">Basketball</option>
                            <option value="Rugby">Rugby</option>
                            <option value="Volleyball">Volleyball</option>
                            <option value="Hockey">Hockey</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="educationFilter">Filter by Education Level:</label>
                        <select id="educationFilter" onchange="filterTalents()">
                            <option value="">All Levels</option>
                            <option value="High School">High School</option>
                            <option value="Undergraduate">Undergraduate</option>
                        </select>
                    </div>
                    <div style="display: flex; align-items: flex-end;">
                        <button onclick="resetFilters()" style="width: 100%; padding: 12px; background-color: #666; color: #fff; border: none; border-radius: 5px; cursor: pointer; font-weight: 600;">Reset Filters</button>
                    </div>
                </div>
            </div>

            <div class="cards-grid">
                <% talents.forEach(talent =>{
                    %>
                    <div class="card">
                        <div class="card-header">
                            <h3><%= talent.fullname %></h3>
                            <span class="sport-badge"><%= talent.sport %></span>

                        </div>
                        <div class="card-content">
                            <p><strong>DoB:</strong> years old</p>
                            <p><strong>Sport:</strong> <%= talent.sport %></p>
                            <p><strong>Education Level:</strong> <span class="badge"><%= talent.education_level %></span></p>
                            <p><strong>Achievement:</strong> <%= talent.highest_achievement %></p>
                            <p><strong>Contact:</strong></p>
                            <p>📧 <%= talent.email %></p>
                            <p>📱 <%= talent.phone %></p>
                             <form action="/deletetalent" method="POST" style="margin-top:10px">
                                <input type="hidden" name="email" value="<%= talent.email %>">
                                <button type="submit" class="btn" style="background-color:#ef4444">Delete</button>
                            </form>
                        </div>
                    </div>
                    <%
                }) %>
            </div>
            <div id="noResults" class="no-results" style="display: none;">
                <p>No talents found matching your criteria. Try adjusting your filters.</p>
            </div>
        </div>
    </main>

    <footer>
        <p>&copy; 2026 TalentRoute. All rights reserved.</p>
        <p>Connecting athletic talent with opportunities worldwide</p>
    </footer>

    <script>
       const talents = <%- JSON.stringify(talents) %>;
        function calculateAge(dob) {
            const today = new Date();
            const birthDate = new Date(dob);
            let age = today.getFullYear() - birthDate.getFullYear();
            const monthDiff = today.getMonth() - birthDate.getMonth();
            if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
                age--;
            }
            return age;
        }

        function displayTalents(data) {
            const container = document.getElementById('talentsContainer');
            const noResults = document.getElementById('noResults');

            if (data.length === 0) {
                container.innerHTML = '';
                noResults.style.display = 'block';
                return;
            }

            noResults.style.display = 'none';
            container.innerHTML = data.map(talent => {
                const age = calculateAge(talent.dob);
                return `
                    <div class="card">
                        <div class="card-header">
                            <h3>${talent.fullname}</h3>
                            <span class="sport-badge">${talent.sport}</span>
                        </div>
                        <div class="card-content">
                            <p><strong>Age:</strong> ${age} years old</p>
                            <p><strong>Sport:</strong> ${talent.sport}</p>
                            <p><strong>Education Level:</strong> <span class="badge">${talent.education}</span></p>
                            <p><strong>Achievement:</strong> ${talent.achievement}</p>
                            <p><strong>Contact:</strong></p>
                            <p>📧 ${talent.email}</p>
                            <p>📱 ${talent.phone}</p>
                        </div>
                        
                    </div>
                `;
            }).join('');
        }

        function filterTalents() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const sportFilter = document.getElementById('sportFilter').value;
            const educationFilter = document.getElementById('educationFilter').value;

            const filtered = talents.filter(talent => {
                const matchesSearch = talent.fullname.toLowerCase().includes(searchTerm) ||
                                    talent.sport.toLowerCase().includes(searchTerm);
                const matchesSport = !sportFilter || talent.sport === sportFilter;
                const matchesEducation = !educationFilter || talent.education === educationFilter;

                return matchesSearch && matchesSport && matchesEducation;
            });

            displayTalents(filtered);
        }

        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('sportFilter').value = '';
            document.getElementById('educationFilter').value = '';
            displayTalents(talents);
        }

        // Initial display
        displayTalents(talents);

        // Search on Enter key
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                filterTalents();
            }
        });
    </script>
</body>
</html>